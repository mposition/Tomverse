generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ==========================================

model User {
  id                            String        @id @default(cuid())
  name                          String?
  email                         String?       @unique
  emailVerified                 DateTime?
  image                         String?
  plan                          String        @default("Free") // "Free", "Pro", "Max"
  stripeCustomerId              String?       @unique
  stripeSubscriptionId          String?       @unique
  stripePriceId                 String?
  subscriptionStatus            String?
  subscriptionCurrentPeriodEnd  DateTime?
  subscriptionBillingInterval   String?
  subscriptionCancelAtPeriodEnd Boolean       @default(false)
  creditDebtCredits             Int           @default(0)
  creditDebtCostMicroUsd        BigInt        @default(0)
  billingRiskStatus             String        @default("normal")
  billingRiskReason             String?
  billingRiskAt                 DateTime?
  createdAt                     DateTime?     @default(now())
  settings                      UserSettings?

  accounts               Account[]
  sessions               Session[]
  projects               ConversationProject[]
  refundRequests         RefundRequest[]
  promotionRedemptions   BillingPromotionRedemption[]
  billingTransactions    BillingTransaction[]
  creditPurchases        CreditPurchase[]
  creditLots             CreditLot[]
  creditLedgerEntries    CreditLedgerEntry[]
  creditDebtEntries      CreditDebtEntry[]
  chatCreditReservations ChatCreditReservation[]
  adminAuditLogs         AdminAuditLog[]
  adminNotes             AdminNote[]
  modelOverrides         ModelOverride[]
  conversations          Conversation[]
  comparisonReviews      ComparisonReview[]
  productAnalyticsEvents ProductAnalyticsEvent[]

  @@index([plan, id])
  @@index([createdAt])
  @@index([subscriptionStatus, subscriptionCurrentPeriodEnd])
  @@index([subscriptionCancelAtPeriodEnd, subscriptionStatus])
  @@index([billingRiskStatus])
  @@index([creditDebtCredits])
  @@index([creditDebtCostMicroUsd])
}

model UserSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  theme                  String    @default("dark") // "dark", "light", "system"
  language               String    @default("en") // "ko", "en"
  defaultModel           String    @default("gpt-5-4-mini")
  preferredTasks         Json?
  preferredPriority      String?
  usesFilesFrequently    String?
  modelFinderCompletedAt DateTime?
  modelFinderDismissedAt DateTime?
  timeZone              String    @default("UTC")
  timeZoneInitializedAt DateTime?
  timeZoneChangedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// ==========================================

model Conversation {
  id        String  @id @default(cuid())
  userId    String
  title     String
  projectId String?

  selectedModels String @default("[\"gpt-5-4-mini\"]")
  disabledPanels String @default("[]")

  shareToken     String?   @unique
  shareEnabled   Boolean   @default(false)
  sharedAt       DateTime?
  shareSnapshot  Json?
  shareExpiresAt DateTime?
  shareRevokedAt DateTime?

  messages          Message[]
  comparisonReviews ComparisonReview[]
  user              User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  project           ConversationProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  password          String?

  @@index([userId, projectId])
}

model ConversationProject {
  id            String         @id @default(cuid())
  userId        String
  name          String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([userId, name])
  @@index([userId, updatedAt])
}

model Message {
  id      String  @id @default(cuid())
  role    String
  content String
  status  String  @default("normal")
  modelId String?

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}

model ComparisonReview {
  id                  String       @id @default(cuid())
  userId              String
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversationId      String
  conversation        Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  promptMessageId     String
  assistantMessageIds Json
  reviewerModelId     String
  reviewMode          String
  promptVersion       String
  result              Json
  usageCredits        Int
  inputHash           String
  isStale             Boolean      @default(false)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@unique([userId, inputHash])
  @@index([conversationId, createdAt])
  @@index([conversationId, isStale])
}

model ProductAnalyticsEvent {
  id              String   @id @default(cuid())
  dedupeKey       String   @unique
  eventName       String
  source          String
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  anonymousIdHash String
  sessionIdHash   String
  utmSource       String
  utmMedium       String
  utmCampaign     String
  language        String
  country         String
  modelCount      Int
  plan            String
  properties      Json?
  occurredAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([eventName, occurredAt])
  @@index([userId, occurredAt])
  @@index([anonymousIdHash, occurredAt])
  @@index([utmSource, utmCampaign, occurredAt])
}

model ChatUsageBucket {
  key         String
  period      String
  periodStart DateTime
  count       Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@id([key, period, periodStart])
  @@index([updatedAt])
}

model ProviderErrorEvent {
  id             String   @id @default(cuid())
  provider       String
  modelId        String?
  phase          String
  diagnosticCode String
  traceId        String
  errorName      String?
  errorCode      String?
  httpStatus     Int?
  retryable      Boolean?
  message        String?
  createdAt      DateTime @default(now())

  @@index([provider, createdAt])
  @@index([provider, diagnosticCode, createdAt])
  @@index([modelId, createdAt])
  @@index([traceId])
}

model ChatRequestLease {
  id         String   @id
  subjectKey String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([subjectKey, expiresAt])
}

model BillingPlan {
  id                  String   @id
  name                String
  tier                String
  monthlyPriceCents   Int
  currency            String   @default("USD")
  stripeProductId     String?
  stripePriceId       String?
  annualPriceCents    Int?
  stripeAnnualPriceId String?
  dailyMessageLimit   Int      @default(0)
  monthlyMessageLimit Int      @default(0)
  maxModels           Int      @default(3)
  allowAttachments    Boolean  @default(true)
  allowSharing        Boolean  @default(true)
  allowDownloads      Boolean  @default(true)
  isActive            Boolean  @default(true)
  sortOrder           Int      @default(0)
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tier])
  @@index([isActive, sortOrder])
}

model BillingPromotion {
  id                    String                       @id @default(cuid())
  code                  String                       @unique
  discountPercent       Int                          @default(0)
  discountAmountCents   Int?
  maxRedemptions        Int?
  redeemedCount         Int                          @default(0)
  durationMonths        Int
  fulfillmentType       String                       @default("stripe_subscription")
  accessDurationDays    Int?
  appliesToPlanIds      String                       @default("[]")
  stripeCouponId        String?
  stripePromotionCodeId String?
  startsAt              DateTime?
  endsAt                DateTime?
  allowAnnualStacking   Boolean                      @default(false)
  isActive              Boolean                      @default(true)
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  redemptions           BillingPromotionRedemption[]

  @@index([isActive])
  @@index([startsAt, endsAt])
}

model BillingPromotionRedemption {
  id                           String           @id @default(cuid())
  promotionId                  String
  promotion                    BillingPromotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  userId                       String
  user                         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId                       String
  billingInterval              String
  stripeCheckoutSessionId      String?          @unique
  stripeSubscriptionId         String?
  clientIpHash                 String?
  paymentMethodFingerprintHash String?
  riskFlags                    String           @default("[]")
  accessStartsAt               DateTime?
  accessEndsAt                 DateTime?
  reminderSentAt               DateTime?
  expiredAt                    DateTime?
  expiryNoticeSentAt           DateTime?
  redeemedAt                   DateTime         @default(now())
  createdAt                    DateTime         @default(now())
  updatedAt                    DateTime         @updatedAt

  @@unique([promotionId, userId])
  @@index([promotionId, redeemedAt])
  @@index([promotionId, clientIpHash, redeemedAt])
  @@index([promotionId, paymentMethodFingerprintHash, redeemedAt])
  @@index([userId, redeemedAt])
  @@index([accessEndsAt, reminderSentAt])
  @@index([accessEndsAt, expiredAt])
}

model BillingTransaction {
  id                      String   @id @default(cuid())
  userId                  String?
  user                    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  productType             String
  productId               String
  billingInterval         String?
  stripeCheckoutSessionId String   @unique
  stripePaymentIntentId   String?
  stripeSubscriptionId    String?
  amountPaidMinor         Int
  currency                String
  amountPaidUsdMicroUsd   BigInt
  usdConversionRate       String?
  usdConversionSource     String
  pricingVersion          Int      @default(1)
  status                  String   @default("paid")
  paidAt                  DateTime
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([userId, paidAt])
  @@index([productType, paidAt])
  @@index([currency, paidAt])
  @@index([stripePaymentIntentId])
  @@index([stripeSubscriptionId])
}

model CreditPurchase {
  id                         String              @id @default(cuid())
  userId                     String
  user                       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  packId                     String
  stripeCheckoutSessionId    String              @unique
  stripePaymentIntentId      String?             @unique
  stripeChargeId             String?             @unique
  creditsPurchased           Int
  fundedCostMicroUsd         BigInt
  amountPaidCents            Int
  amountPaidUsdMicroUsd      BigInt              @default(0)
  refundedAmountCents        Int                 @default(0)
  revokedCredits             Int                 @default(0)
  revokedCostMicroUsd        BigInt              @default(0)
  unrecoveredCredits         Int                 @default(0)
  unrecoveredCostMicroUsd    BigInt              @default(0)
  stripeDisputeId            String?             @unique
  disputeStatus              String?
  disputeAmountCents         Int                 @default(0)
  disputeRevokedCredits      Int                 @default(0)
  disputeRevokedCostMicroUsd BigInt              @default(0)
  disputeDebtCredits         Int                 @default(0)
  disputeDebtCostMicroUsd    BigInt              @default(0)
  disputeOffsetCredits       Int                 @default(0)
  disputeOffsetCostMicroUsd  BigInt              @default(0)
  currency                   String              @default("USD")
  status                     String              @default("paid")
  purchasedAt                DateTime            @default(now())
  expiresAt                  DateTime
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
  lots                       CreditLot[]
  ledgerEntries              CreditLedgerEntry[]
  debtEntries                CreditDebtEntry[]

  @@index([userId, purchasedAt])
  @@index([status, purchasedAt])
  @@index([stripePaymentIntentId])
}

model CreditLot {
  id                          String              @id @default(cuid())
  userId                      String
  user                        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchaseId                  String?
  purchase                    CreditPurchase?     @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  source                      String
  originalCredits             Int
  remainingCredits            Int
  originalFundedCostMicroUsd  BigInt              @default(0)
  remainingFundedCostMicroUsd BigInt              @default(0)
  expiresAt                   DateTime
  status                      String              @default("active")
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
  ledgerEntries               CreditLedgerEntry[]

  @@index([userId, status, expiresAt])
  @@index([purchaseId])
}

model CreditLedgerEntry {
  id                             String          @id @default(cuid())
  userId                         String
  user                           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditLotId                    String
  creditLot                      CreditLot       @relation(fields: [creditLotId], references: [id], onDelete: Cascade)
  purchaseId                     String?
  purchase                       CreditPurchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  type                           String
  creditsDelta                   Int
  fundedCostMicroUsdDelta        BigInt          @default(0)
  balanceAfterCredits            Int
  balanceAfterFundedCostMicroUsd BigInt          @default(0)
  reservationId                  String?
  metadata                       Json?
  createdAt                      DateTime        @default(now())

  @@index([userId, createdAt])
  @@index([creditLotId, createdAt])
  @@index([purchaseId, createdAt])
  @@index([reservationId])
}

model CreditDebtEntry {
  id                       String          @id @default(cuid())
  userId                   String
  user                     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchaseId               String?
  purchase                 CreditPurchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  type                     String
  creditsDelta             Int
  fundedCostMicroUsdDelta  BigInt          @default(0)
  balanceAfterCredits      Int
  balanceAfterCostMicroUsd BigInt          @default(0)
  metadata                 Json?
  createdAt                DateTime        @default(now())

  @@index([userId, createdAt])
  @@index([purchaseId, createdAt])
  @@index([type, createdAt])
}

model ChatCreditReservation {
  id                       String    @id
  userId                   String?
  user                     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  subjectKey               String
  traceId                  String
  source                   String
  provider                 String
  modelId                  String
  status                   String    @default("reserved")
  outcome                  String?
  idempotencyKey           String    @unique
  providerRequestId        String?
  providerResponseId       String?
  providerRequestLinkedAt  DateTime?
  reservationPayload       Json
  reservedCredits          Int
  reservedCostMicroUsd     BigInt
  planReservedCredits      Int
  addOnReservedCredits     Int
  settledCredits           Int       @default(0)
  settledCostMicroUsd      BigInt    @default(0)
  settledInputTokens       Int       @default(0)
  settledCachedInputTokens Int       @default(0)
  settledOutputTokens      Int       @default(0)
  pricingSnapshot          Json?
  providerUsageSnapshot    Json?
  expiresAt                DateTime
  settledAt                DateTime?
  reconciledAt             DateTime?
  lastError                String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([status, expiresAt])
  @@index([userId, createdAt])
  @@index([traceId])
  @@index([providerRequestId])
  @@index([providerResponseId])
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Feedback {
  id              String   @id @default(cuid())
  userId          String?
  email           String?
  type            String
  status          String   @default("open")
  message         String
  traceId         String?
  modelId         String?
  plan            String?
  hasAttachments  Boolean  @default(false)
  attachmentCount Int      @default(0)
  path            String?
  userAgent       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, createdAt])
  @@index([type, createdAt])
  @@index([userId, createdAt])
}

model RefundRequest {
  id                           String                       @id @default(cuid())
  userId                       String?
  user                         User?                        @relation(fields: [userId], references: [id], onDelete: SetNull)
  email                        String?
  plan                         String?
  stripeCustomerId             String?
  stripeSubscriptionId         String?
  subscriptionStatus           String?
  subscriptionCurrentPeriodEnd DateTime?
  subscriptionBillingInterval  String?
  reason                       String?
  status                       String                       @default("pending")
  adminNote                    String?
  reviewedByUserId             String?
  stripeRefundId               String?
  stripeRefundStatus           String?
  stripeChargeId               String?
  refundAmountCents            Int?
  refundCurrency               String?
  requestedAt                  DateTime                     @default(now())
  reviewedAt                   DateTime?
  updatedAt                    DateTime                     @updatedAt
  timelineEvents               RefundRequestTimelineEvent[]

  @@index([status, requestedAt])
  @@index([userId, requestedAt])
  @@index([email])
}

model RefundRequestTimelineEvent {
  id              String        @id @default(cuid())
  refundRequestId String
  refundRequest   RefundRequest @relation(fields: [refundRequestId], references: [id], onDelete: Cascade)
  actorUserId     String?
  actorEmail      String?
  eventType       String
  message         String
  metadata        Json?
  createdAt       DateTime      @default(now())

  @@index([refundRequestId, createdAt])
  @@index([eventType, createdAt])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorEmail  String?
  action      String
  targetType  String
  targetId    String?
  summary     String
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([targetType, targetId])
  @@index([actorUserId, createdAt])
}

model AdminActionApproval {
  id               String    @id @default(cuid())
  action           String
  targetType       String
  targetId         String?
  status           String    @default("pending")
  reason           String?
  payload          Json?
  requestedById    String?
  requestedByEmail String?
  reviewedById     String?
  reviewedByEmail  String?
  reviewedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
}

model AdminNote {
  id             String   @id @default(cuid())
  targetType     String
  targetId       String
  body           String
  createdById    String?
  createdBy      User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdByEmail String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([targetType, targetId, createdAt])
  @@index([createdById, createdAt])
}

model ModelOverride {
  modelId        String   @id
  status         String
  reason         String?
  visibleNote    String?
  updatedById    String?
  updatedBy      User?    @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  updatedByEmail String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
}

/// Database-backed source of truth for AI models. Rows are retired instead of
/// physically removed so historical conversations can still resolve model IDs.
model ModelRegistryEntry {
  id                              String   @id
  name                            String
  apiModel                        String
  provider                        String
  apiBaseUrl                      String
  apiKeyEnvName                   String
  icon                            String   @default("")
  bestFor                         String   @default("")
  minimumPlan                     String
  usageClass                      String
  creditWeight                    Int
  publiclyListed                  Boolean  @default(true)
  enabled                         Boolean  @default(true)
  status                          String   @default("enabled")
  operationalReason               String?
  userVisibleNote                 String?
  replacementModelId              String?
  catalogDeleted                  Boolean  @default(false)
  reasoning                       String?
  contextWindowTokens             Int?
  supportsImage                   Boolean  @default(false)
  supportsNativePdf               Boolean  @default(false)
  maxImages                       Int?
  maxBase64ImagePayloadBytes      Int?
  maxOutputTokens                 Int?
  reservationOutputTokens        Int?
  inputUsdPerMillionTokens        Float?
  outputUsdPerMillionTokens       Float?
  cachedInputPriceMultiplier      Float?
  sortOrder                       Int      @default(0)
  updatedById                     String?
  updatedByEmail                  String?
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt

  @@index([provider, sortOrder])
  @@index([status, catalogDeleted])
  @@index([publiclyListed, enabled, catalogDeleted])
}

model AdminNotificationLog {
  id                  String    @id @default(cuid())
  channel             String
  title               String
  detail              String
  status              String
  targetType          String?
  targetId            String?
  error               String?
  acknowledgedAt      DateTime?
  acknowledgedById    String?
  acknowledgedByEmail String?
  createdAt           DateTime  @default(now())

  @@index([channel, createdAt])
  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@index([acknowledgedAt])
}

model AdminAlertPolicy {
  id                       String   @id @default(cuid())
  name                     String
  provider                 String?
  isActive                 Boolean  @default(true)
  budgetThresholds         String   @default("[50,80,95]")
  providerFailureThreshold Int      @default(5)
  modelFailureThreshold    Int      @default(3)
  notifyEmail              Boolean  @default(true)
  notifySlack              Boolean  @default(false)
  notifyDiscord            Boolean  @default(false)
  createdById              String?
  createdByEmail           String?
  updatedById              String?
  updatedByEmail           String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([isActive])
  @@index([provider])
}

model AdminProviderIncident {
  id               String    @id @default(cuid())
  provider         String?
  modelId          String?
  status           String    @default("limited")
  title            String
  message          String?
  fallbackModelIds String    @default("[]")
  previousModelStates Json?
  createdById      String?
  createdByEmail   String?
  resolvedById     String?
  resolvedByEmail  String?
  startsAt         DateTime  @default(now())
  resolvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([provider, status])
  @@index([modelId, status])
}

model ProviderHealthCheck {
  id             String   @id @default(cuid())
  provider       String
  modelId        String?
  status         String
  latencyMs      Int?
  errorCode      String?
  message        String?
  createdById    String?
  createdByEmail String?
  createdAt      DateTime @default(now())

  @@index([provider, createdAt])
  @@index([status, createdAt])
}

model ProviderDailyUsage {
  id                           String    @id @default(cuid())
  provider                     String
  modelId                      String    @default("__provider__")
  source                       String    @default("internal")
  date                         DateTime
  requestCount                 Int       @default(0)
  inputTokens                  Int       @default(0)
  cachedInputTokens            Int       @default(0)
  outputTokens                 Int       @default(0)
  estimatedCostMicroUsd        Int       @default(0)
  uncachedInputCostMicroUsd    Int       @default(0)
  cachedInputCostMicroUsd      Int       @default(0)
  outputCostMicroUsd           Int       @default(0)
  providerReportedCostMicroUsd Int?
  providerReportedUsageJson    Json?
  syncedAt                     DateTime?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  @@unique([provider, modelId, source, date])
  @@index([provider, date])
  @@index([date])
  @@index([source, date])
}

model ProviderCreditConfig {
  provider              String   @id
  creditMicroUsd        BigInt
  usageBaselineMicroUsd BigInt
  note                  String?
  updatedById           String?
  updatedByEmail        String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model ProviderBillingConfig {
  provider             String    @id
  pricingModel         String
  settlementModel      String
  currency             String    @default("USD")
  monthlyLimitMicroUsd BigInt?
  source               String    @default("admin_verified")
  verifiedAt           DateTime?
  note                 String?
  updatedById          String?
  updatedByEmail       String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model InfrastructureCreditConfig {
  service        String   @id
  creditMicroUsd BigInt
  note           String?
  updatedById    String?
  updatedByEmail String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model StripeWebhookEventLog {
  id              String    @id @default(cuid())
  stripeEventId   String?   @unique
  eventType       String
  status          String
  error           String?
  receivedAt      DateTime  @default(now())
  processedAt     DateTime?
  replayedAt      DateTime?
  replayedById    String?
  replayedByEmail String?
  payloadSummary  Json?

  @@index([status, receivedAt])
  @@index([eventType, receivedAt])
}

model AdminRetentionRun {
  id             String   @id @default(cuid())
  mode           String
  status         String
  result         Json?
  error          String?
  createdById    String?
  createdByEmail String?
  createdAt      DateTime @default(now())

  @@index([mode, createdAt])
  @@index([status, createdAt])
}

model AdminOperationReport {
  id             String   @id @default(cuid())
  title          String
  body           String
  status         String
  recipient      String?
  createdById    String?
  createdByEmail String?
  createdAt      DateTime @default(now())

  @@index([status, createdAt])
  @@index([createdById, createdAt])
}
