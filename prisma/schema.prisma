generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ==========================================

model User {
  id                            String        @id @default(cuid())
  name                          String?
  email                         String?       @unique
  emailVerified                 DateTime?
  image                         String?
  plan                          String        @default("Free") // "Free", "Pro", "Max"
  stripeCustomerId              String?       @unique
  stripeSubscriptionId          String?       @unique
  stripePriceId                 String?
  subscriptionStatus            String?
  subscriptionCurrentPeriodEnd  DateTime?
  subscriptionBillingInterval   String?
  subscriptionCancelAtPeriodEnd Boolean       @default(false)
  settings                      UserSettings?

  accounts             Account[]
  sessions             Session[]
  projects             ConversationProject[]
  refundRequests       RefundRequest[]
  promotionRedemptions BillingPromotionRedemption[]
  adminAuditLogs       AdminAuditLog[]
  adminNotes           AdminNote[]
  modelOverrides       ModelOverride[]
  conversations        Conversation[]
}

model UserSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  theme        String @default("dark") // "dark", "light", "system"
  language     String @default("en") // "ko", "en"
  defaultModel String @default("gpt-5-4-mini")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// ==========================================

model Conversation {
  id        String  @id @default(cuid())
  userId    String
  title     String
  projectId String?

  selectedModels String @default("[\"gpt-5-4-mini\"]")
  disabledPanels String @default("[]")

  shareToken     String?   @unique
  shareEnabled   Boolean   @default(false)
  sharedAt       DateTime?
  shareSnapshot  Json?
  shareExpiresAt DateTime?
  shareRevokedAt DateTime?

  messages  Message[]
  user      User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   ConversationProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  password  String?

  @@index([userId, projectId])
}

model ConversationProject {
  id            String         @id @default(cuid())
  userId        String
  name          String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([userId, name])
  @@index([userId, updatedAt])
}

model Message {
  id      String  @id @default(cuid())
  role    String
  content String
  status  String  @default("normal")
  modelId String?

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}

model ChatUsageBucket {
  key         String
  period      String
  periodStart DateTime
  count       Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@id([key, period, periodStart])
  @@index([updatedAt])
}

model ChatRequestLease {
  id         String   @id
  subjectKey String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([subjectKey, expiresAt])
}

model BillingPlan {
  id                  String   @id
  name                String
  tier                String
  monthlyPriceCents   Int
  currency            String   @default("USD")
  stripeProductId     String?
  stripePriceId       String?
  annualPriceCents    Int?
  stripeAnnualPriceId String?
  dailyMessageLimit   Int      @default(0)
  monthlyMessageLimit Int      @default(0)
  maxModels           Int      @default(3)
  allowAttachments    Boolean  @default(true)
  allowSharing        Boolean  @default(true)
  allowDownloads      Boolean  @default(true)
  isActive            Boolean  @default(true)
  sortOrder           Int      @default(0)
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tier])
  @@index([isActive, sortOrder])
}

model BillingPromotion {
  id                    String                       @id @default(cuid())
  code                  String                       @unique
  discountPercent       Int                          @default(0)
  discountAmountCents   Int?
  maxRedemptions        Int?
  redeemedCount         Int                          @default(0)
  durationMonths        Int
  appliesToPlanIds      String                       @default("[]")
  stripeCouponId        String?
  stripePromotionCodeId String?
  startsAt              DateTime?
  endsAt                DateTime?
  isActive              Boolean                      @default(true)
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  redemptions           BillingPromotionRedemption[]

  @@index([isActive])
  @@index([startsAt, endsAt])
}

model BillingPromotionRedemption {
  id                      String           @id @default(cuid())
  promotionId             String
  promotion               BillingPromotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  userId                  String
  user                    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId                  String
  billingInterval         String
  stripeCheckoutSessionId String?          @unique
  stripeSubscriptionId    String?
  redeemedAt              DateTime         @default(now())
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  @@unique([promotionId, userId])
  @@index([promotionId, redeemedAt])
  @@index([userId, redeemedAt])
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Feedback {
  id              String   @id @default(cuid())
  userId          String?
  email           String?
  type            String
  status          String   @default("open")
  message         String
  traceId         String?
  modelId         String?
  plan            String?
  hasAttachments  Boolean  @default(false)
  attachmentCount Int      @default(0)
  path            String?
  userAgent       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, createdAt])
  @@index([type, createdAt])
  @@index([userId, createdAt])
}

model RefundRequest {
  id                           String                       @id @default(cuid())
  userId                       String?
  user                         User?                        @relation(fields: [userId], references: [id], onDelete: SetNull)
  email                        String?
  plan                         String?
  stripeCustomerId             String?
  stripeSubscriptionId         String?
  subscriptionStatus           String?
  subscriptionCurrentPeriodEnd DateTime?
  subscriptionBillingInterval  String?
  reason                       String?
  status                       String                       @default("pending")
  adminNote                    String?
  reviewedByUserId             String?
  stripeRefundId               String?
  stripeRefundStatus           String?
  stripeChargeId               String?
  refundAmountCents            Int?
  requestedAt                  DateTime                     @default(now())
  reviewedAt                   DateTime?
  updatedAt                    DateTime                     @updatedAt
  timelineEvents               RefundRequestTimelineEvent[]

  @@index([status, requestedAt])
  @@index([userId, requestedAt])
  @@index([email])
}

model RefundRequestTimelineEvent {
  id              String        @id @default(cuid())
  refundRequestId String
  refundRequest   RefundRequest @relation(fields: [refundRequestId], references: [id], onDelete: Cascade)
  actorUserId     String?
  actorEmail      String?
  eventType       String
  message         String
  metadata        Json?
  createdAt       DateTime      @default(now())

  @@index([refundRequestId, createdAt])
  @@index([eventType, createdAt])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorEmail  String?
  action      String
  targetType  String
  targetId    String?
  summary     String
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([targetType, targetId])
  @@index([actorUserId, createdAt])
}

model AdminActionApproval {
  id              String    @id @default(cuid())
  action          String
  targetType      String
  targetId        String?
  status          String    @default("pending")
  reason          String?
  payload         Json?
  requestedById   String?
  requestedByEmail String?
  reviewedById    String?
  reviewedByEmail String?
  reviewedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
}

model AdminNote {
  id             String   @id @default(cuid())
  targetType     String
  targetId       String
  body           String
  createdById    String?
  createdBy      User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdByEmail String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([targetType, targetId, createdAt])
  @@index([createdById, createdAt])
}

model ModelOverride {
  modelId        String   @id
  status         String
  reason         String?
  visibleNote    String?
  updatedById    String?
  updatedBy      User?    @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  updatedByEmail String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
}

model AdminNotificationLog {
  id                  String    @id @default(cuid())
  channel             String
  title               String
  detail              String
  status              String
  targetType          String?
  targetId            String?
  error               String?
  acknowledgedAt      DateTime?
  acknowledgedById    String?
  acknowledgedByEmail String?
  createdAt           DateTime  @default(now())

  @@index([channel, createdAt])
  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@index([acknowledgedAt])
}

model AdminAlertPolicy {
  id                       String   @id @default(cuid())
  name                     String
  provider                 String?
  isActive                 Boolean  @default(true)
  budgetThresholds         String   @default("[50,80,95]")
  providerFailureThreshold Int      @default(5)
  modelFailureThreshold    Int      @default(3)
  notifyEmail              Boolean  @default(true)
  notifySlack              Boolean  @default(false)
  notifyDiscord            Boolean  @default(false)
  createdById              String?
  createdByEmail           String?
  updatedById              String?
  updatedByEmail           String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([isActive])
  @@index([provider])
}

model AdminProviderIncident {
  id               String    @id @default(cuid())
  provider         String?
  modelId          String?
  status           String    @default("limited")
  title            String
  message          String?
  fallbackModelIds String    @default("[]")
  createdById      String?
  createdByEmail   String?
  resolvedById     String?
  resolvedByEmail  String?
  startsAt         DateTime  @default(now())
  resolvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([provider, status])
  @@index([modelId, status])
}

model ProviderHealthCheck {
  id             String   @id @default(cuid())
  provider       String
  modelId        String?
  status         String
  latencyMs      Int?
  errorCode      String?
  message        String?
  createdById    String?
  createdByEmail String?
  createdAt      DateTime @default(now())

  @@index([provider, createdAt])
  @@index([status, createdAt])
}

model ProviderDailyUsage {
  id                           String   @id @default(cuid())
  provider                     String
  modelId                      String   @default("__provider__")
  source                       String   @default("internal")
  date                         DateTime
  requestCount                 Int      @default(0)
  inputTokens                  Int      @default(0)
  outputTokens                 Int      @default(0)
  estimatedCostMicroUsd        Int      @default(0)
  providerReportedCostMicroUsd Int?
  providerReportedUsageJson    Json?
  syncedAt                     DateTime?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  @@unique([provider, modelId, source, date])
  @@index([provider, date])
  @@index([date])
  @@index([source, date])
}

model StripeWebhookEventLog {
  id              String    @id @default(cuid())
  stripeEventId   String?   @unique
  eventType       String
  status          String
  error           String?
  receivedAt      DateTime  @default(now())
  processedAt     DateTime?
  replayedAt      DateTime?
  replayedById    String?
  replayedByEmail String?
  payloadSummary  Json?

  @@index([status, receivedAt])
  @@index([eventType, receivedAt])
}

model AdminRetentionRun {
  id             String   @id @default(cuid())
  mode           String
  status         String
  result         Json?
  error          String?
  createdById    String?
  createdByEmail String?
  createdAt      DateTime @default(now())

  @@index([mode, createdAt])
  @@index([status, createdAt])
}

model AdminOperationReport {
  id             String   @id @default(cuid())
  title          String
  body           String
  status         String
  recipient      String?
  createdById    String?
  createdByEmail String?
  createdAt      DateTime @default(now())

  @@index([status, createdAt])
  @@index([createdById, createdAt])
}
