generator client {
// 💡 Prisma 7에서는 provider가 변경되었습니다.
  provider = "prisma-client-js"   
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 💡 [신규 추가] NextAuth 필수 및 사용자 커스텀 모델
// ==========================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  plan          String    @default("Free") // "Free", "Pro", "Max"
  
  // 💡 커스텀 설정 필드 (테마, 언어 등)
  settings      UserSettings?
  
  accounts      Account[]
  sessions      Session[]
  conversations Conversation[] // 사용자가 가진 대화방들
}

model UserSettings {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  theme          String   @default("dark")      // "dark", "light", "system"
  language       String   @default("en")        // "ko", "en"
  defaultModel  String   @default("gpt-5-4-mini") // 중앙 모델 레지스트리의 기본 모델

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// 대화방과 메시지
// ==========================================

model Conversation {
  id             String    @id @default(cuid())
  userId         String
  title          String
  
  // 💡 대화방별 패널 상태를 기억하기 위한 필드 추가
  // 💡 String[] 대신 일반 String으로 변경 (SQLite 호환성 확보)
  selectedModels String    @default("[\"gpt-5-4-mini\"]")
  disabledPanels String    @default("[]")
  
  shareToken     String?   @unique
  shareEnabled   Boolean   @default(false)
  sharedAt       DateTime?
  shareSnapshot  Json?
  shareExpiresAt DateTime?
  shareRevokedAt DateTime?
    
  messages       Message[]
  user           User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  password       String?   // 💡 잠금 비밀번호 (null이면 잠금 해제 상태)
}

model Message {
  id             String       @id @default(cuid())
  role           String
  content        String
  status         String       @default("normal")
  modelId        String?      // 💡 어떤 AI 모델이 쓴 답변인지 구분하는 꼬리표 추가
  
  conversationId String  
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}

model ChatUsageBucket {
  key         String
  period      String
  periodStart DateTime
  count       Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@id([key, period, periodStart])
  @@index([updatedAt])
}

model ChatRequestLease {
  id         String   @id
  subjectKey String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([subjectKey, expiresAt])
}
