{
  "name": "ai-chat-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "start:e2e": "next start -H 127.0.0.1 -p 3100",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test:e2e:quick": "node scripts/run-e2e.mjs --project=desktop-chromium",
    "test:e2e:ui": "npm run build && playwright test --ui",
    "capture:marketing-proof": "node scripts/capture-marketing-proof.mjs",
    "capture:week1-marketing-kit": "node scripts/capture-week1-marketing-kit.mjs",
    "validate:week1-marketing-kit": "node scripts/validate-week1-marketing-kit.mjs",
    "capture:week1-marketing-kit:en": "node scripts/capture-week1-marketing-kit-en.mjs",
    "validate:week1-marketing-kit:en": "node scripts/validate-week1-marketing-kit-en.mjs",
    "test:db:integration": "node scripts/run-db-integration-tests.mjs",
    "test:admin": "node --conditions=react-server --import tsx --test tests/admin-auth-core.test.ts tests/admin-approval-core.test.ts tests/admin-audit-integrity-core.test.ts",
    "test:unit": "node scripts/run-unit-tests.mjs",
    "lint": "eslint",
    "check": "eslint . --max-warnings=0 && next typegen && tsc --noEmit --incremental false && next build",
    "check:encoding": "node scripts/check-text-encoding.mjs",
    "check:encoding:strict": "node scripts/check-text-encoding.mjs --strict",
    "security:regression": "node scripts/security-regression-check.mjs",
    "db:migrate": "node scripts/require-direct-database-url.mjs && prisma migrate deploy",
    "maintenance:cleanup": "node scripts/run-maintenance.mjs",
    "maintenance:credit-reservations": "node scripts/run-credit-reconciliation.mjs",
    "maintenance:provider-usage": "node scripts/run-provider-usage-sync.mjs",
    "maintenance:provider-model-catalog": "node scripts/run-provider-model-catalog-monitor.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.8",
    "@ai-sdk/google": "^4.0.8",
    "@ai-sdk/openai": "^4.0.7",
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1083.0",
    "@aws-sdk/s3-request-presigner": "^3.1083.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/config": "^7.8.0",
    "@sentry/nextjs": "^10.65.0",
    "ai": "^7.0.15",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "next-auth": "^4.24.14",
    "officeparser": "^7.2.3",
    "openai": "^6.45.0",
    "pdfjs-dist": "^6.1.200",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "stripe": "^22.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "uuid": "11.1.1",
    "next": {
      "postcss": "8.5.10"
    }
  }
}
